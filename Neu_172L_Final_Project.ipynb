      "source": [
        "## Demographic information data visualization ##\n",
        "demo_df.columns = demo_df.columns.str.strip()\n",
        "plt.figure(figsize=(14, 6))\n",
        "\n",
        "# Bar plot for Age Distribution\n",
        "plt.subplot(1, 2, 1)\n",
        "sns.countplot(data=demo_df, x='age', palette='viridis')\n",
        "plt.title('Distribution of Age')\n",
        "plt.xlabel('Age')\n",
        "plt.ylabel('Count')\n",
        "\n",
        "# Bar plot for Ethnicity Distribution\n",
        "plt.subplot(1, 2, 2)\n",
        "sns.countplot(data=demo_df, x='ethnicity', palette='plasma')\n",
        "plt.title('Distribution of Ethnicity')\n",
        "plt.xlabel('Ethnicity')\n",
        "plt.ylabel('Count')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show();"
      ],
