      "source": [
        "## Compare All Models\n",
        "\n",
        "Now, let's gather the accuracy scores from the Neural Network, K-Nearest Neighbors, Logistic Regression, and the tuned SVM model, and compare them visually."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 941
        },
        "id": "ba480f83",
        "outputId": "012c3cf5-8dd3-462f-f464-f87c74e372a7"
      },
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import pandas as pd\n",
        "import torch\n",
        "from sklearn.metrics import accuracy_score\n",
        "\n",
        "# --- 1. Gather Predictions ---\n",
        "\n",
        "# A. Naive Neural Network (Keras)\n",
        "# Returns probabilities (N, 1), we convert to flattened binary predictions\n",
        "if 'model' in locals():\n",
        "    y_pred_nn_prob = model.predict(X_test, verbose=0)\n",
        "    y_pred_nn = (y_pred_nn_prob > 0.5).astype(int).flatten()\n",
        "    acc_nn = accuracy_score(y_test, y_pred_nn)\n",
        "else:\n",
        "    acc_nn = 0\n",
        "    print(\"Warning: Naive NN 'model' not found.\")\n",
        "\n",
        "# B. Standard ML Models (sklearn)\n",
        "y_pred_svm = svm_model.predict(X_test)\n",
        "acc_svm = accuracy_score(y_test, y_pred_svm)\n",
        "\n",
        "y_pred_knn = knn_model.predict(X_test)\n",
        "acc_knn = accuracy_score(y_test, y_pred_knn)\n",
        "\n",
        "y_pred_log = log_reg_model.predict(X_test)\n",
        "acc_log = accuracy_score(y_test, y_pred_log)\n",
        "\n",
        "# --- 2. Build Score Dictionary ---\n",
        "scores_data = [\n",
        "    {'Model': 'Naive Neural Network', 'Accuracy': acc_nn},\n",
        "    {'Model': 'SVM (Poly)', 'Accuracy': acc_svm},\n",
        "    {'Model': 'k-Nearest Neighbors', 'Accuracy': acc_knn},\n",
        "    {'Model': 'Logistic Regression', 'Accuracy': acc_log}\n",
        "]\n",
        "\n",
        "# Create a df for the models\n",
        "accuracy_df = pd.DataFrame(scores_data)\n",
        "accuracy_df = accuracy_df.sort_values(by='Accuracy', ascending=False).reset_index(drop=True)\n",
        "\n",
        "# Calculate difference from best model\n",
        "best_acc = accuracy_df['Accuracy'].max()\n",
        "accuracy_df['Diff from Best'] = accuracy_df['Accuracy'] - best_acc\n",
        "\n",
        "print(\"\\nModel Performance Ranking:\")\n",
        "print(accuracy_df)\n",
        "\n",
        "# Visualization\n",
        "plt.figure(figsize=(12, 7))\n",
        "plot = sns.barplot(x='Model', y='Accuracy', data=accuracy_df, palette='viridis')\n",
        "\n",
        "plt.title('Final Model Comparison: Which architecture performs best?', fontsize=16)\n",
        "plt.ylim(0, 1.0) # Accuracy is 0-1\n",
        "plt.ylabel('Accuracy Score', fontsize=12)\n",
        "plt.xlabel('Model Architecture', fontsize=12)\n",
        "plt.xticks(rotation=15)\n",
        "plt.grid(axis='y', linestyle='--', alpha=0.7)\n",
        "\n",
        "for p in plot.patches:\n",
        "    plot.annotate(format(p.get_height(), '.4f'),\n",
        "                   (p.get_x() + p.get_width() / 2., p.get_height()),\n",
        "                   ha = 'center', va = 'center',\n",
        "                   xytext = (0, 9),\n",
        "                   textcoords = 'offset points',\n",
        "                   fontweight='bold')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
