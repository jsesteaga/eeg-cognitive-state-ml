    {
      "cell_type": "code",
      "source": [
        "## Data Cleaning\n",
        "data_merged = merged_df.copy()\n",
        "# Drop SubjectID & VideoID\n",
        "data_merged.drop(['SubjectID', 'VideoID', 'predefinedlabel'], axis=1, inplace=True)\n",
        "# We want to make a model that is going to work well on any set of subjects and videos\n",
        "data_merged.rename(columns={'user-definedlabeln' : 'Label'}, inplace=True)\n",
        "data_merged['Label'] = data_merged['Label'].astype(int)\n",
        "# Change M in gender to 0 and F to 1\n",
        "data_merged['gender'] = data_merged['gender'].map({'M': 0, 'F': 1})\n",
        "# One-hot encode 'ethnicity' column\n",
        "eth_dummies = pd.get_dummies(data_merged['ethnicity']).astype(int)\n",
        "# Concatenate the one-hot encoded columns with the original DataFrame\n",
        "data_merged = pd.concat([data_merged, eth_dummies], axis=1)\n",
        "data_merged.drop('ethnicity', axis=1, inplace=True)\n",
        "\n",
        "data_merged.head()"
      ],
