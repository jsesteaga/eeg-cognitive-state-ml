        "nn_probs = model.predict(X_test, verbose=0).flatten()\n",
        "nn_preds = (nn_probs > 0.5).astype(\"int32\")\n",
        "\n",
        "preds_dict = {\n",
        "    'k-Nearest Neighbors': knn_model.predict(X_test),\n",
        "    'Logistic Regression': log_reg_model.predict(X_test),\n",
        "    'SVM (Poly)': svm_model.predict(X_test),\n",
        "    'Neural Network': nn_preds  # Added NN Class Labels\n",
        "}\n",
        "\n",
        "probs_dict = {\n",
        "    'k-Nearest Neighbors': knn_model.predict_proba(X_test)[:, 1],\n",
        "    'Logistic Regression': log_reg_model.predict_proba(X_test)[:, 1],\n",
        "    'SVM (Poly)': svm_model.decision_function(X_test),\n",
        "    'Neural Network': nn_probs\n",
        "}\n",
        "\n",
        "# Side-by-side heat map\n",
        "plt.figure(figsize=(20, 5))\n",
        "for i, (name, preds) in enumerate(preds_dict.items(), 1):\n",
        "    plt.subplot(1, 4, i)\n",
        "    cm = confusion_matrix(y_test, preds)\n",
        "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', cbar=False)\n",
        "    plt.title(f'{name}\\nAccuracy: {accuracy_score(y_test, preds):.2f}')\n",
        "    plt.xlabel('Predicted')\n",
        "    plt.ylabel('Actual')\n",
        "    plt.xticks([0.5, 1.5], ['Not Confused', 'Confused'])\n",
        "    plt.yticks([0.5, 1.5], ['Not Confused', 'Confused'])\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# ROC Curve Comparison\n",
        "plt.figure(figsize=(10, 8))\n",
        "for name, probs in probs_dict.items():\n",
        "    fpr, tpr, _ = roc_curve(y_test, probs)\n",
        "    roc_auc = auc(fpr, tpr)\n",
