      },
      "source": [
        "y = data_merged['Label']\n",
        "X = data_merged.drop(['Label', 'subject ID', 'age'], axis=1)\n",
        "\n",
        "numerical_cols = ['Attention', 'Mediation', 'Raw', 'Delta', 'Theta', 'Alpha1', 'Alpha2', 'Beta1', 'Beta2', 'Gamma1', 'Gamma2']\n",
